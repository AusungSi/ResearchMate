APP_NAME=MemoMate
APP_ENV=development
APP_PROFILE=research_local
APP_HOST=0.0.0.0
APP_PORT=8000
LOG_LEVEL=INFO
CONDA_ENV_NAME=memomate
RESEARCH_LOCAL_USER_ID=local-single-user
RESEARCH_LOCAL_USER_LOCALE=zh-CN

DB_URL=sqlite:///./data/memomate.db
SCHEDULER_INTERVAL_SECONDS=15
REMINDER_RETRY_MINUTES=5

WECOM_TOKEN=replace-me
WECOM_AES_KEY=replace-me
WECOM_CORP_ID=replace-me
WECOM_AGENT_ID=1000002
WECOM_SECRET=replace-me

OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_MODEL=qwen3:8b
OLLAMA_TIMEOUT_SECONDS=30
OLLAMA_INTENT_TEMPERATURE=0.0
OLLAMA_NLG_TEMPERATURE=0.2
OLLAMA_NLG_MODEL=
INTENT_PROVIDER=openclaw
INTENT_LOCAL_BACKEND=ollama
INTENT_EXTERNAL_BASE_URL=
INTENT_EXTERNAL_API_KEY=
INTENT_MODEL=
INTENT_TIMEOUT_SECONDS=30
INTENT_RETRIES=2
INTENT_FALLBACK_ENABLED=true
REPLY_PROVIDER=local
REPLY_LOCAL_BACKEND=ollama
REPLY_EXTERNAL_BASE_URL=
REPLY_EXTERNAL_API_KEY=
REPLY_MODEL=
REPLY_TIMEOUT_SECONDS=30
REPLY_RETRIES=2
REPLY_FALLBACK_ENABLED=true

# OpenClaw Auto 模式配置
# 如果要启用原生 OpenClaw 自动调研，请至少填写：
# OPENCLAW_ENABLED=true
# OPENCLAW_BASE_URL=...
# OPENCLAW_GATEWAY_TOKEN=...
OPENCLAW_ENABLED=false
OPENCLAW_BASE_URL=http://127.0.0.1:18789
OPENCLAW_GATEWAY_TOKEN=
OPENCLAW_AGENT_ID=main
OPENCLAW_TIMEOUT_SECONDS=30
OPENCLAW_RETRIES=2
OPENCLAW_CLI_PATH=~/.openclaw/bin/openclaw
OPENCLAW_CLI_FALLBACK_ENABLED=true

# GPT Step 模式配置
# 只要你使用 GPT API，这里至少需要填写：
# RESEARCH_GPT_API_KEY=你的_API_Key
# 如果你走兼容 OpenAI 的服务，也可以修改 RESEARCH_GPT_BASE_URL
RESEARCH_GPT_BASE_URL=https://api.openai.com/v1
RESEARCH_GPT_API_KEY=
RESEARCH_GPT_MODEL=gpt-5.4
RESEARCH_GPT_TIMEOUT_SECONDS=60

ASR_PROVIDER=local
ASR_ENABLED=true
ASR_LOCAL_MODEL=large-v3
ASR_LOCAL_DEVICE=cpu
ASR_LOCAL_COMPUTE_TYPE=int8
ASR_TIMEOUT_SECONDS=120
ASR_MAX_AUDIO_SECONDS=60
ASR_EXTERNAL_PROVIDER=iflytek
ASR_EXTERNAL_ENABLED=false
ASR_IFLYTEK_APP_ID=
ASR_IFLYTEK_API_KEY=
ASR_IFLYTEK_API_SECRET=
ASR_IFLYTEK_BASE_URL=
ASR_FALLBACK_ENABLED=true
FALLBACK_ORDER=external,local,template

JWT_SECRET=change-this-secret-to-at-least-32-chars
JWT_ALGORITHM=HS256
ACCESS_TOKEN_MINUTES=60
REFRESH_TOKEN_DAYS=30

DEFAULT_TIMEZONE=Asia/Shanghai
PENDING_ACTION_MINUTES=10
PAIR_CODE_MINUTES=10

RESEARCH_ENABLED=true
RESEARCH_JOB_INTERVAL_SECONDS=20
RESEARCH_JOB_MAX_ATTEMPTS=3
RESEARCH_JOB_BACKOFF_SECONDS=10
RESEARCH_QUEUE_MODE=worker
RESEARCH_QUEUE_NAME=research
RESEARCH_WORKER_POLL_SECONDS=2
RESEARCH_WORKER_CONCURRENCY=2
RESEARCH_JOB_LEASE_SECONDS=120
RESEARCH_JOB_HEARTBEAT_SECONDS=15
RESEARCH_DIRECTION_MIN=3
RESEARCH_DIRECTION_MAX=8
RESEARCH_TOPN_DEFAULT=20
RESEARCH_SEED_TOPN_DEFAULT=60
RESEARCH_SEED_MAX_ABSTRACT_CHARS=600
RESEARCH_ROUND_TOPN_DEFAULT=12
RESEARCH_PAGE_SIZE=10
RESEARCH_SOURCES_DEFAULT=semantic_scholar,arxiv
RESEARCH_ARTIFACT_DIR=./artifacts/research
RESEARCH_SAVE_BASE_DIR=./artifacts/research/saved
RESEARCH_CACHE_ENABLED=true
RESEARCH_CACHE_TTL_SECONDS=86400
RESEARCH_EXPORT_SEND_FILE=true
RESEARCH_METRICS_ENABLED=true
RESEARCH_FULLTEXT_ENABLED=true
RESEARCH_FULLTEXT_MAX_FILE_MB=30
RESEARCH_FULLTEXT_TIMEOUT_SECONDS=45
RESEARCH_FULLTEXT_RETRIES=2
RESEARCH_GRAPH_ENABLED=true
RESEARCH_GRAPH_DEPTH_DEFAULT=1
RESEARCH_GRAPH_SEED_TOPN=20
RESEARCH_GRAPH_EXPAND_LIMIT_PER_PAPER=30
RESEARCH_GRAPH_VIZ_ENABLED=true
RESEARCH_EXPLORATION_ENABLED=true
RESEARCH_MAX_ROUNDS=10
RESEARCH_ROUND_CANDIDATE_DEFAULT=4
RESEARCH_CITATION_SOURCES_DEFAULT=semantic_scholar,openalex,crossref
RESEARCH_CITATION_ON_DEMAND_ONLY=true
RESEARCH_CITATION_CACHE_TTL_SECONDS=86400
RESEARCH_WECOM_LITE_MODE=true
RESEARCH_WEB_BASE_URL=
RESEARCH_OCR_ENABLED=false
RESEARCH_GRAPH_PAPER_LIMIT_DEFAULT=8
RESEARCH_SUMMARY_ENABLED=true
RESEARCH_SUMMARY_MAX_CHARS=8000
# 如果你希望论文检索更稳定，建议填写 Semantic Scholar Key
# 否则在无 key 情况下，检索有可能碰到 429 rate limit
SEMANTIC_SCHOLAR_API_KEY=

CF_TUNNEL_MODE=quick
CF_TUNNEL_NAME=memomate
CF_TUNNEL_ID=
CF_TUNNEL_HOSTNAME=memomate.example.com
CF_TUNNEL_LOCAL_URL=http://localhost:8000
CF_TUNNEL_CONFIG_FILE=.cloudflared/config.yml
WECOM_CALLBACK_URL=
